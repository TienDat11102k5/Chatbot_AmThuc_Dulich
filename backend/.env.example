# =============================================================================
# BACKEND ENVIRONMENT VARIABLES - Spring Boot
# Copy file này thành .env và điều chỉnh các giá trị theo môi trường
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_USERNAME=admin
DB_PASSWORD=password

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# =============================================================================
# EMAIL CONFIGURATION (Tùy chọn)
# =============================================================================
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16_characters

# =============================================================================
# GOOGLE OAUTH (Tùy chọn)
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# =============================================================================
# LƯU Ý:
# - DB_USERNAME và DB_PASSWORD phải khớp với docker-compose.yml
# - JWT_SECRET có thể dùng giá trị mặc định cho demo
# - Email và Google OAuth là tùy chọn
# =============================================================================