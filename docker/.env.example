# =============================================================================
# ENVIRONMENT VARIABLES - Chatbot Ẩm Thực & Du Lịch
# Copy file này thành .env và điều chỉnh các giá trị theo môi trường thực tế
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_USERNAME=admin
DB_PASSWORD=password

# =============================================================================
# JWT AUTHENTICATION
# Thay đổi JWT_SECRET khi triển khai production
# =============================================================================
JWT_SECRET=demo_jwt_secret_key_for_testing_please_change_in_production

# =============================================================================
# EMAIL CONFIGURATION (Tùy chọn - chỉ cần khi test gửi email OTP)
# Hướng dẫn tạo Gmail App Password:
# 1. Vào Google Account Settings
# 2. Security > 2-Step Verification
# 3. App passwords > Generate password
# =============================================================================
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16_characters

# =============================================================================
# GOOGLE OAUTH (Tùy chọn - chỉ cần khi test đăng nhập Google)
# Hướng dẫn tạo Google Client ID:
# 1. Vào Google Cloud Console
# 2. APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# =============================================================================
# LƯU Ý QUAN TRỌNG:
# - Nếu không tạo file .env, hệ thống sẽ dùng giá trị mặc định
# - Chỉ cần cấu hình email và Google OAuth khi muốn test đầy đủ tính năng
# - Để demo cơ bản, chỉ cần chạy: docker compose up -d
# =============================================================================