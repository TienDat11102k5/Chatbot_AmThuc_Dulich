# =============================================================================
# AI SERVICE ENVIRONMENT VARIABLES - FastAPI
# Copy file này thành .env và điều chỉnh các giá trị theo môi trường
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# Khi chạy Docker: sử dụng tên service "database"
# Khi chạy local: sử dụng "localhost"
# =============================================================================
DB_HOST=database
DB_PORT=5432
DB_NAME=chatbot_db
DB_USER=admin
DB_PASSWORD=password

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================
AI_SERVICE_PORT=8000

# =============================================================================
# LƯU Ý:
# - DB_HOST=database khi chạy trong Docker
# - DB_HOST=localhost khi chạy local development
# - DB_USER và DB_PASSWORD phải khớp với docker-compose.yml
# =============================================================================